# ── External API keys ──────────────────────────────────────────────────────
# Required: Gemini (all agents use gemini-2.0-flash)
GOOGLE_API_KEY=your_google_api_key_here

# Required: OpenAI (used only by embed_corpus.py for text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Required: Cohere (used by RAG agent for reranking)
COHERE_API_KEY=your_cohere_api_key_here

# Optional: LangSmith tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=mega-ai

# ── Database ────────────────────────────────────────────────────────────────
# Async driver — used by FastAPI / SQLAlchemy async engine
DATABASE_URL=postgresql+asyncpg://mega:mega@localhost:5434/megaai

# Sync driver — used by Alembic, Celery worker, sync_pool
DATABASE_URL_SYNC=postgresql://mega:mega@localhost:5434/megaai

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Postgres credentials (used by docker-compose) ───────────────────────────
POSTGRES_USER=mega
POSTGRES_PASSWORD=mega
POSTGRES_DB=megaai

# ── Agent budget ────────────────────────────────────────────────────────────
MAX_AGENT_BUDGET_TOKENS=8000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
