# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── External API keys ────────────────────────────────────────────────────────

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-replace-me

# Cohere API key (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=replace-me

# ── Database ──────────────────────────────────────────────────────────────────

# Async connection string used by SQLAlchemy + asyncpg (FastAPI / background tasks)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mega_ai

# Sync connection string used by Celery workers (psycopg2)
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/mega_ai

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis URL used as Celery broker and result backend
REDIS_URL=redis://localhost:6379/0

# ── LangSmith tracing (optional) ─────────────────────────────────────────────

# LangSmith API key — leave blank to disable tracing
LANGCHAIN_API_KEY=

# Set to "true" to enable LangSmith trace uploads
LANGCHAIN_TRACING_V2=false

# LangSmith project name traces will be grouped under
LANGCHAIN_PROJECT=mega-ai

# ── Logging ───────────────────────────────────────────────────────────────────

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Agent budget ─────────────────────────────────────────────────────────────

# Maximum tokens allocated per agent run before it is forced to stop
MAX_AGENT_BUDGET_TOKENS=8000
